{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./out/preload",
    "rootDir": "./src"
  },
  "include": ["src/preload/**/*", "src/shared/**/*"]
}
