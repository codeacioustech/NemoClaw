{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./out/renderer",
    "rootDir": "./src",
    "jsx": "preserve"
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"]
}
