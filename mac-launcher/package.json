{
  "name": "nemoclaw-mac-launcher",
  "version": "0.1.0",
  "description": "macOS desktop launcher for NemoClaw",
  "main": "index.js",
  "scripts": {
    "prestart": "bash scripts/download-ollama.sh && (test -f ../nemoclaw/dist/index.js || (cd ../nemoclaw && npm install --ignore-scripts && npx tsc))",
    "start": "electron .",
    "dist": "npm run download-ollama && electron-builder",
    "download-ollama": "bash scripts/download-ollama.sh"
  },
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@buape/carbon": "0.0.0-beta-20260216184201",
    "@larksuiteoapi/node-sdk": "*",
    "@mariozechner/pi-ai": "0.64.0",
    "@mariozechner/pi-coding-agent": "0.64.0",
    "@matrix-org/matrix-sdk-crypto-wasm": "18.0.0",
    "@sinclair/typebox": "0.34.49",
    "chokidar": "^5.0.0",
    "file-type": "22.0.0",
    "gaxios": "7.1.4",
    "hono": "4.12.9",
    "long": "^5.3.2",
    "osc-progress": "^0.3.0",
    "sqlite-vec": "0.1.9",
    "tslog": "^4.10.2",
    "openclaw": "2026.3.11",
    "nemoclaw": "file:../nemoclaw"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.nemoclaw.launcher",
    "productName": "NemoClaw",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "asar": false,
    "extraResources": [
      {
        "from": "resources/ollama-mac",
        "to": "ollama-mac"
      }
    ],
    "files": [
      "index.js",
      "preload.js",
      "splash.html",
      "lib/**"
    ]
  }
}
