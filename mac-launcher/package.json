{
  "name": "nemoclaw-mac-launcher",
  "version": "0.1.0",
  "description": "macOS desktop launcher for NemoClaw",
  "main": "index.js",
  "scripts": {
    "prestart": "test -f ../nemoclaw/dist/index.js || (cd ../nemoclaw && npm install --ignore-scripts && npx tsc)",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -v 37.0.0",
    "postinstall": "electron-rebuild",
    "dist": "electron-builder",
    "dist:dmg": "SKIP_OLLAMA=1 bash scripts/build-dmg.sh",
    "download-ollama": "bash scripts/download-ollama.sh"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.17.1",
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@aws-sdk/client-bedrock": "3.1020.0",
    "@buape/carbon": "0.0.0-beta-20260216184201",
    "@clack/prompts": "^1.1.0",
    "@grammyjs/runner": "*",
    "@grammyjs/transformer-throttler": "*",
    "@homebridge/ciao": "^1.3.6",
    "@jimp/utils": "*",
    "@larksuiteoapi/node-sdk": "*",
    "@line/bot-sdk": "^10.6.0",
    "@lydell/node-pty": "1.2.0-beta.3",
    "@mariozechner/pi-agent-core": "0.64.0",
    "@mariozechner/pi-ai": "0.64.0",
    "@mariozechner/pi-coding-agent": "0.64.0",
    "@mariozechner/pi-tui": "0.64.0",
    "@matrix-org/matrix-sdk-crypto-wasm": "18.0.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@sinclair/typebox": "0.34.49",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "*",
    "ajv": "^8.18.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "file-type": "22.0.0",
    "gaxios": "7.1.4",
    "grammy": "^1.41.1",
    "hono": "4.12.9",
    "https-proxy-agent": "*",
    "ipaddr.js": "^2.3.0",
    "jimp": "*",
    "jiti": "^2.6.1",
    "json5": "^2.2.3",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "long": "^5.3.2",
    "markdown-it": "^14.1.1",
    "matrix-js-sdk": "41.3.0-rc.0",
    "nemoclaw": "file:../nemoclaw",
    "node-edge-tts": "^1.2.10",
    "openai": "*",
    "openclaw": "2026.4.14",
    "osc-progress": "^0.3.0",
    "p-queue": "*",
    "pdfjs-dist": "^5.6.205",
    "playwright-core": "1.58.2",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5",
    "sqlite-vec": "0.1.9",
    "tar": "7.5.13",
    "tslog": "^4.10.2",
    "undici": "^7.24.6",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.nemoclaw.launcher",
    "productName": "NemoClaw",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "identity": "Apple Development: piyush_mishra31@outlook.com (F94354ST5N)",
      "hardenedRuntime": true,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist",
      "gatekeeperAssess": false
    },
    "asar": false,
    "npmRebuild": false,
    "afterPack": "./scripts/afterPack.js",
    "extraResources": [],
    "files": [
      "**/*",
      "!scripts",
      "!resources"
    ]
  }
}
