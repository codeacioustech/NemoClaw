{
  "name": "nemoclaw-mac-launcher",
  "version": "1.0.0",
  "description": "NemoClaw macOS desktop launcher — standalone Electron app wrapping the OpenClaw gateway",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "chmod +x resources/ollama-mac/ollama 2>/dev/null || true",
    "build": "npm run prebuild && npx electron-builder",
    "build:clean": "npm install && npm run build",
    "download-ollama": "bash scripts/download-ollama.sh"
  },
  "dependencies": {
    "openclaw": "^2026.3.31"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.nemoclaw.launcher",
    "productName": "NemoClaw",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!resources/ollama-mac",
      "!node_modules/openclaw/docs",
      "!node_modules/openclaw/assets",
      "!node_modules/openclaw/CHANGELOG.md",
      "!node_modules/pdfjs-dist",
      "!node_modules/@napi-rs",
      "!node_modules/@matrix-org",
      "!node_modules/matrix-js-sdk",
      "!node_modules/matrix-widget-api",
      "!node_modules/@line",
      "!node_modules/@google/genai",
      "!node_modules/@anthropic-ai",
      "!node_modules/@mistralai",
      "!node_modules/@aws-sdk",
      "!node_modules/@smithy",
      "!node_modules/@mariozechner",
      "!node_modules/@silvia-odwyer",
      "!node_modules/telegraf",
      "!node_modules/openai",
      "!node_modules/playwright-core"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/openclaw/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "icon.icns"
    },
    "extraResources": [
      {
        "from": "resources/ollama-mac",
        "to": "ollama-mac"
      }
    ]
  }
}
