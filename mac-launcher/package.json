{
  "name": "nemoclaw-mac-launcher",
  "version": "1.0.0",
  "description": "NemoClaw macOS desktop launcher",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build": "npx electron-builder"
  },
  "build": {
    "appId": "com.nemoclaw.launcher",
    "productName": "NemoClaw",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.js",
      "preload.js"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.2"
  }
}
