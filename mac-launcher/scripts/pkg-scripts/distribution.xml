<installer-gui-script minSpecVersion="2">
    <title>NemoClaw</title>
    <welcome file="welcome.html" mime-type="text/html"/>
    <options customize="never" require-scripts="false" hostArchitectures="arm64,x86_64"/>
    <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true"/>
    <choices-outline>
        <line choice="default">
            <line choice="com.nemoclaw.launcher"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.nemoclaw.launcher" visible="false">
        <pkg-ref id="com.nemoclaw.launcher"/>
    </choice>
    <pkg-ref id="com.nemoclaw.launcher" version="0.1.0" onConclusion="none">NemoClaw-component.pkg</pkg-ref>
</installer-gui-script>
